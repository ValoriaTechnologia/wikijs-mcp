# Configuration du serveur MCP WikiJS

# URL de base de WikiJS
# Exemple: https://wiki.example.com
WIKIJS_URL=https://wiki.example.com

# Endpoint GraphQL de WikiJS
# Si non défini, sera construit automatiquement: {WIKIJS_URL}/graphql
# Exemple: https://wiki.example.com/graphql
WIKIJS_GRAPHQL_ENDPOINT=

# Clé API WikiJS pour authentifier les requêtes GraphQL
# Générée dans WikiJS avec les droits de lecture
# Exemple: votre_cle_api_ici
WIKIJS_API_KEY=your_api_key_here

# Configuration du transport MCP
# 'stdio' pour usage local, 'sse' pour accès réseau
MCP_TRANSPORT=sse

# Configuration du serveur réseau (si MCP_TRANSPORT=sse)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Configuration OAuth Keycloak pour l'authentification du serveur MCP
# Si KEYCLOAK_REALM est défini, le serveur utilisera OAuth avec Keycloak pour authentifier les clients MCP.
# Laissez vide pour désactiver l'authentification.

# Mode simple (rétrocompatible) : utilise la même URL pour PUBLIC et INTERNAL
# URL de base de Keycloak (ex: https://keycloak.example.com)
KEYCLOAK_URL=

# Mode avancé (URLs séparées) : utilise des URLs différentes pour PUBLIC et INTERNAL
# URL publique de Keycloak pour les redirections navigateur (ex: https://keycloak.example.com)
KEYCLOAK_PUBLIC_URL=
# URL interne de Keycloak pour les appels API backend (ex: http://keycloak:8080 pour Docker)
KEYCLOAK_INTERNAL_URL=

# Nom du realm Keycloak (ex: wikijs-mcp)
KEYCLOAK_REALM=

# ID du client OAuth dans Keycloak (doit être créé dans Keycloak)
KEYCLOAK_CLIENT_ID=

# Secret du client (requis pour client confidentiel, optionnel pour client public)
KEYCLOAK_CLIENT_SECRET=

# Scopes OAuth requis (défaut: openid profile email)
KEYCLOAK_SCOPES=openid profile email

# URL publique du serveur MCP (utilisée pour construire les URLs de callback OAuth)
# Pour développement local: http://localhost:8000
# Pour production: https://your-server.com
MCP_BASE_URL=http://localhost:8000
